APP_NAME="Event Visuals"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=event_visuals
DB_TEST_DATABASE=event_visuals_testing
DB_USERNAME=sail
DB_PASSWORD=password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

EVENT_SEED_PROFILE=dev
EVENT_SEED=event-visuals-v1
EVENT_SEED_REFERENCE_AT=2026-07-20T12:00:00Z
EVENT_SEED_ALLOW_FULL=false

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE=mail
REDIS_QUEUE_RETRY_AFTER=90

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

HORIZON_NAME=event-visuals-local
HORIZON_PREFIX=event_visuals_horizon:

MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=local-event-visuals-meilisearch-master-key
MEILISEARCH_EVENT_INDEX=events_v1
MEILISEARCH_TIMEOUT=5
MEILISEARCH_BUILD_TIMEOUT_MS=1800000
MEILISEARCH_RECONCILE_TIMEOUT_MS=30000
MEILISEARCH_TASK_POLL_INTERVAL_MS=200
MEILISEARCH_DATABASE_CHUNK_SIZE=2000
MEILISEARCH_BATCH_DOCUMENT_LIMIT=10000
MEILISEARCH_BATCH_BYTE_LIMIT=8388608
MEILISEARCH_TASK_QUERY_CHUNK_SIZE=100
MEILISEARCH_MAX_TOTAL_HITS=1000
FORWARD_MEILISEARCH_PORT=17730
MEILI_DB_PATH=/meili_data/data.ms
MEILI_ENV=development
MEILI_NO_ANALYTICS=true

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="events@example.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_MAPBOX_ACCESS_TOKEN=
VITE_MAPBOX_STYLE=mapbox://styles/mapbox/standard

COMPOSE_PROJECT_NAME=event-visuals
APP_SERVICE=laravel.test
APP_PORT=80
VITE_PORT=5173
FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025
FORWARD_DB_PORT=13306
NODE_VERSION=22
WWWUSER=1000
WWWGROUP=1000
SAIL_XDEBUG_MODE=off
